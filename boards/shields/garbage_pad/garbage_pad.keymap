#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
	keymap {
		compatible = "zmk,keymap";
		
		default_layer {
			bindings = <
				&kp Q &kp W &kp E &kp R &kp T &kp Y &kp U &kp I &kp O &kp P &kp BSPC
                		&kp A &none &kp S &kp D &kp F &kp G &kp H &kp J &kp K &kp L &kp ENTER 
                		&kp Z &kp X &kp C &kp V &kp B &kp N &none &kp M &kp COMMA &kp DOT &kp FSLH
                		&none &kp A &kp A &none &kp A &none  &kp A &none &kp A &kp A &none
			>;
		};
	};
};
